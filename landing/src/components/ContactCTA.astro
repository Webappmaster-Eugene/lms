---
const LMS_URL = 'https://lms.nadtocheev.ru'
---

<section id="contacts" class="section-padding border-t border-white/5 relative overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[500px] w-[500px] rounded-full bg-brand-600/15 blur-[120px]"></div>
  </div>

  <div class="container-narrow text-center">
    <h2 class="text-3xl font-bold text-white sm:text-4xl">
      Готов начать?
    </h2>
    <p class="mt-4 text-lg text-gray-400 max-w-xl mx-auto">
      Присоединяйся к платформе MentorCareer и начни свой путь в разработке
      уже сегодня.
    </p>

    <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a href={LMS_URL} class="btn-primary text-base px-8 py-4">
        Начать обучение
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <!-- Contact cards -->
    <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 max-w-3xl mx-auto">
      <a href="https://t.me/eugene_nadtocheev" target="_blank" rel="noopener noreferrer" class="card flex flex-col items-center gap-2 py-5">
        <svg class="h-6 w-6 text-brand-400" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        <span class="text-sm text-gray-300">Telegram</span>
      </a>

      <a href="https://t.me/mentorcareer_chat" target="_blank" rel="noopener noreferrer" class="card flex flex-col items-center gap-2 py-5">
        <svg class="h-6 w-6 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 6.1H3"></path><path d="M21 12.1H3"></path><path d="M15.1 18H3"></path></svg>
        <span class="text-sm text-gray-300">Чат учеников</span>
      </a>

      <a href="mailto:johnn.hotmail@mail.ru" class="card flex flex-col items-center gap-2 py-5">
        <svg class="h-6 w-6 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
        <span class="text-sm text-gray-300">Email</span>
      </a>

      <a href="https://nadtocheev.ru" target="_blank" rel="noopener noreferrer" class="card flex flex-col items-center gap-2 py-5">
        <svg class="h-6 w-6 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20"></path><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        <span class="text-sm text-gray-300">Сайт автора</span>
      </a>
    </div>
  </div>
</section>
