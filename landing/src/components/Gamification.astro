<section id="gamification" class="section-padding border-t border-white/5 relative overflow-hidden">
  <div class="absolute top-0 right-0 h-[400px] w-[400px] rounded-full bg-yellow-500/10 blur-[120px] -z-10"></div>

  <div class="container-narrow">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 rounded-full bg-yellow-500/10 border border-yellow-500/20 px-3 py-1 text-xs font-medium text-yellow-400 mb-4">
        Мотивация
      </div>
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Учёба как игра
      </h2>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
        Геймификация — не гаджет, а проверенный метод. Когда видишь прогресс и
        соревнуешься — учиться интереснее и эффективнее.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
      <!-- Points -->
      <div class="card text-center lg:col-span-1">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-yellow-500/10">
          <svg class="h-6 w-6 text-yellow-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </div>
        <p class="text-2xl font-bold text-white">XP</p>
        <p class="text-xs text-gray-500 mt-1">10 за урок<br/>50 за курс<br/>200 за роадмап</p>
      </div>

      <!-- Achievements -->
      <div class="card text-center lg:col-span-1">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-purple-500/10">
          <svg class="h-6 w-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
        </div>
        <p class="text-2xl font-bold text-white">8+</p>
        <p class="text-xs text-gray-500 mt-1">Достижений<br/>за milestone'ы</p>
      </div>

      <!-- Streaks -->
      <div class="card text-center lg:col-span-1">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-orange-500/10">
          <svg class="h-6 w-6 text-orange-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path></svg>
        </div>
        <p class="text-2xl font-bold text-white">Стрики</p>
        <p class="text-xs text-gray-500 mt-1">Дни подряд<br/>без перерыва</p>
      </div>

      <!-- Leaderboard -->
      <div class="card text-center lg:col-span-1">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10">
          <svg class="h-6 w-6 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" x2="12" y1="20" y2="10"></line><line x1="18" x2="18" y1="20" y2="4"></line><line x1="6" x2="6" y1="20" y2="16"></line></svg>
        </div>
        <p class="text-2xl font-bold text-white">Top 50</p>
        <p class="text-xs text-gray-500 mt-1">Лидерборд<br/>рейтинг учеников</p>
      </div>

      <!-- Certificates -->
      <div class="card text-center lg:col-span-1">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-green-500/10">
          <svg class="h-6 w-6 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"></circle><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path></svg>
        </div>
        <p class="text-2xl font-bold text-white">Cертификаты</p>
        <p class="text-xs text-gray-500 mt-1">Авто-выдача<br/>за курс/роадмап</p>
      </div>
    </div>
  </div>
</section>
