<section id="trainer" class="section-padding border-t border-white/5 relative overflow-hidden">
  <!-- Bg glow -->
  <div class="absolute top-1/2 left-0 -translate-y-1/2 h-[400px] w-[400px] rounded-full bg-green-500/10 blur-[120px] -z-10"></div>

  <div class="container-narrow">
    <div class="grid gap-12 lg:grid-cols-2 items-center">
      <!-- Text -->
      <div>
        <div class="inline-flex items-center gap-2 rounded-full bg-green-500/10 border border-green-500/20 px-3 py-1 text-xs font-medium text-green-400 mb-4">
          Интерактивная практика
        </div>
        <h2 class="text-3xl font-bold text-white sm:text-4xl">
          Тренажёр кода
        </h2>
        <p class="mt-4 text-lg text-gray-400">
          Не просто смотри видео — пиши код. Встроенный JavaScript-редактор
          с мгновенным выполнением прямо в браузере.
        </p>

        <ul class="mt-8 space-y-4">
          {[
            { title: 'Задачи по темам', desc: 'Переменные, функции, массивы, объекты — от простого к сложному' },
            { title: 'Три уровня сложности', desc: 'Easy, Medium, Hard — выбирай по силам' },
            { title: 'Мгновенная проверка', desc: 'Нажми "Запустить" — увидишь результат. Автоматическое сравнение с ожидаемым выводом' },
            { title: 'Подсказки', desc: 'Застрял? Открой подсказку. Каждая раскрывается по очереди — не спойлерит решение сразу' },
            { title: 'Баллы за решение', desc: '10 XP за каждую решённую задачу — мотивация практиковаться' },
          ].map(({ title, desc }) => (
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 flex-shrink-0 text-green-400 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"></path></svg>
              <div>
                <span class="font-medium text-white">{title}</span>
                <span class="text-gray-400"> — {desc}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Code mock -->
      <div class="rounded-2xl border border-white/10 bg-surface-light overflow-hidden shadow-2xl">
        <!-- Editor header -->
        <div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
          <div class="flex gap-1.5">
            <div class="h-3 w-3 rounded-full bg-red-500/50"></div>
            <div class="h-3 w-3 rounded-full bg-yellow-500/50"></div>
            <div class="h-3 w-3 rounded-full bg-green-500/50"></div>
          </div>
          <span class="text-xs text-gray-500 ml-2">trainer.js</span>
        </div>
        <!-- Code -->
        <div class="p-4 font-mono text-sm leading-7">
          <div><span class="text-gray-500">1</span>  <span class="text-blue-400">function</span> <span class="text-yellow-300">sumArray</span><span class="text-gray-300">(arr) {'{'}</span></div>
          <div><span class="text-gray-500">2</span>    <span class="text-purple-400">return</span> <span class="text-gray-300">arr.</span><span class="text-yellow-300">reduce</span><span class="text-gray-300">((</span><span class="text-orange-300">sum</span><span class="text-gray-300">, </span><span class="text-orange-300">n</span><span class="text-gray-300">) =&gt; sum + n, </span><span class="text-green-300">0</span><span class="text-gray-300">)</span></div>
          <div><span class="text-gray-500">3</span>  <span class="text-gray-300">{'}'}</span></div>
          <div><span class="text-gray-500">4</span></div>
          <div><span class="text-gray-500">5</span>  <span class="text-gray-300">console.</span><span class="text-yellow-300">log</span><span class="text-gray-300">(</span><span class="text-yellow-300">sumArray</span><span class="text-gray-300">([</span><span class="text-green-300">1, 2, 3, 4, 5</span><span class="text-gray-300">]))</span></div>
        </div>
        <!-- Output -->
        <div class="border-t border-white/10 bg-black/20 p-4">
          <div class="flex items-center gap-2 mb-2">
            <div class="h-2 w-2 rounded-full bg-green-400"></div>
            <span class="text-xs text-green-400 font-medium">Задача решена верно!</span>
          </div>
          <div class="font-mono text-sm text-gray-300">
            <span class="text-gray-500">Вывод:</span> 15
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
