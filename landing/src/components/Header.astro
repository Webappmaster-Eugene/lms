---
const LMS_URL = 'https://app.mentorcareer.ru'

const navItems = [
  { href: '#features', label: 'Возможности' },
  { href: '#how-it-works', label: 'Как это работает' },
  { href: '#trainer', label: 'Тренажёр' },
  { href: '#gamification', label: 'Геймификация' },
  { href: '#contacts', label: 'Контакты' },
]
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-surface/80 backdrop-blur-xl">
  <div class="container-narrow flex h-16 items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2.5">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600">
        <svg class="h-4 w-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </svg>
      </div>
      <span class="text-lg font-bold text-white">MentorCareer</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {navItems.map(({ href, label }) => (
        <a href={href} class="text-sm text-gray-400 transition-colors hover:text-white">{label}</a>
      ))}
    </nav>

    <a href={LMS_URL} class="btn-primary text-xs sm:text-sm">
      Начать обучение
    </a>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>
