# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lms_platform

PAYLOAD_SECRET=your-secret-key-min-32-chars-long-here
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Initial admin (required on first launch with empty DB)
ADMIN_EMAIL=admin@mentorcareer.ru
ADMIN_PASSWORD=<strong-password>

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
EMAIL_FROM_ADDRESS=noreply@lms.example.com
EMAIL_FROM_NAME=LMS Platform

# OpenTelemetry (optional, disabled if OTEL_EXPORTER_OTLP_ENDPOINT is empty)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=lms-platform
